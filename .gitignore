# SUAS - Smart Unit Attendance System
# .gitignore - Ignore files that shouldn't be committed

# Environment files (contains sensitive data)
.env
.env.local
.env.production
.env.*.local

# Database files (generated)
*.sql.backup
*.db
*.sqlite

# Logs
*.log
storage/logs/*
!storage/logs/.gitkeep

# Cache
storage/cache/*
!storage/cache/.gitkeep
storage/framework/cache/*
!storage/framework/cache/.gitkeep

# Sessions
storage/sessions/*
!storage/sessions/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Composer
/vendor/
composer.lock

# Node modules (if using frontend build tools)
/node_modules/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Build artifacts
build/
dist/

# PHPUnit
.phpunit.result.cache
phpunit.xml

# Coverage reports
coverage/
.clover.xml
.phpunit/

# Documentation builds
docs/_build/

# Uploaded files (if any)
uploads/
public/uploads/

# Backup files
backups/

# Local configuration overrides
config.local.php
