# SUAS - Smart Unit Attendance System
# Environment Variable Configuration
# Copy this file to .env and configure for your environment

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# --- For Local Development (MySQL) ---
# Set USE_SUPABASE to false for local MySQL development
USE_SUPABASE=false

# MySQL Database Settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
MASTER_DB_NAME=hlsuas_master

# --- For Production (Supabase PostgreSQL) ---
# Set USE_SUPABASE to true for Supabase production deployment
# USE_SUPABASE=true

# Supabase Database Settings
# Get these from your Supabase project dashboard:
# Settings → Database → Connection string
SUPABASE_DB_HOST=db.xxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASS=your-super-secure-password
SUPABASE_MASTER_DB_NAME=postgres

# Alternative: Use DATABASE_URL connection string
# DATABASE_URL=postgresql://postgres:your-password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Application environment (development, staging, production)
APP_ENV=development

# Application URL (without trailing slash)
APP_URL=http://localhost:8000

# Session settings
SESSION_LIFETIME=120
SESSION_SECURE=false

# Error reporting (true for development, false for production)
DEBUG=true

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@suas.app
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# SECURITY
# ===========================================

# Generate a random 32-character string for session security
APP_KEY=

# CSRF protection
CSRF_ENABLED=true

# ===========================================
# FILE STORAGE (Optional)
# ===========================================

# Local file storage path
FILESYSTEM_PATH=./storage

# Or use cloud storage (AWS S3, etc.)
# FILESYSTEM_CLOUD_BUCKET=
