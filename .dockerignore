# SUAS - Smart Unit Attendance System
# .dockerignore - Exclude files from Docker build

# Environment files
.env
.env.local
.env.*.local

# Git
.git
.gitignore
.gitattributes

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
storage/logs/*

# Cache
storage/cache/*
storage/framework/cache/*

# Sessions
storage/sessions/*

# Tests
tests/
phpunit.xml

# Documentation
docs/
*.md
!README.md

# Development files
docker-compose.yml
docker-compose.override.yml

# Build artifacts
vendor/
node_modules/

# Temporary files
tmp/
temp/
*.tmp
